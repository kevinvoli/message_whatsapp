# ==============================
# ENVIRONNEMENT
# ==============================
NODE_ENV=production

# ==============================
# BASE DE DONNÉES MYSQL
# ==============================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=whatsappflow

# ==============================
# SERVEUR
# ==============================
SERVER_PORT=3002
WS_PORT=3005
# URL publique du serveur (utilisée pour les liens médias Meta)
SERVER_PUBLIC_HOST=https://your-domain.com

# ==============================
# CORS — origines autorisées
# ==============================
# Liste d'origines séparées par des virgules (SANS espace autour des virgules)
# ex: http://votre-ip:3000,http://votre-ip:3001,https://votre-domaine.com
CORS_ORIGINS=http://votre-ip:3000,http://votre-ip:3001

# ==============================
# WHAPI (provider WhatsApp)
# ==============================
WHAPI_TOKEN=
WHAPI_URL=https://gate.whapi.cloud/
WHATSAPP_NUMBER=

# Sécurité webhook Whapi (header + valeur attendue)
WHAPI_WEBHOOK_SECRET_HEADER=x-whapi-signature
WHAPI_WEBHOOK_SECRET_VALUE=
WHAPI_WEBHOOK_SECRET_VALUE_PREVIOUS=

# ==============================
# META / WHATSAPP BUSINESS API
# ==============================
META_API_VERSION=v22.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_APP_SECRET_PREVIOUS=

# ==============================
# AUTHENTIFICATION JWT
# ==============================
# Générer avec : openssl rand -base64 64
JWT_SECRET=

# ==============================
# ADMIN (compte initial)
# ==============================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=            # min 12 caractères
ADMIN_NAME=Admin

# ==============================
# CRON
# ==============================
REDISPATCH_CRON=*/30 * * * * *

# ==============================
# FEATURE FLAGS
# ==============================
FF_UNIFIED_WEBHOOK_ROUTER=true
FF_SHADOW_UNIFIED=true
FF_UNIFIED_WHAPI_PCT=100
